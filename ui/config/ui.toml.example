# sena-ui configuration

[grpc]
daemon_bus_address = "http://127.0.0.1:50051"
reactive_loop_address = "http://127.0.0.1:50058"
connection_timeout_ms = 5000

[window]
title = "Sena"
width = 1200.0
height = 800.0

[debug_panel]
width = 420.0
animation_duration_ms = 250
thought_feed_max = 100
event_feed_max = 200

[reconnect]
initial_delay_ms = 0
second_delay_ms = 2000
third_delay_ms = 10000
steady_state_delay_ms = 30000

[logging]
level = "info"
format = "json"

[overlay]
enabled = true
toggle_key = "Insert"

[overlay.health_window]
x = 100.0
y = 100.0
width = 320.0
height = 400.0

[overlay.event_bus_window]
x = 440.0
y = 100.0
width = 500.0
height = 450.0

[overlay.chat_window]
x = 960.0
y = 100.0
width = 400.0
height = 500.0

[overlay.boot_timeline_window]
x = 100.0
y = 520.0
width = 500.0
height = 300.0

[overlay.widget_bar_window]
x = 660.0
y = 20.0
width = 600.0
height = 48.0
